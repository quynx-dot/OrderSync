{
  "name": "ordersync",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "services/shared",
    "services/auth",
    "services/restaurant",
    "services/rider",
    "services/utils",
    "services/admin",
    "services/realtime"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace=services/shared",
    "dev:auth":       "npm run dev --workspace=services/auth",
    "dev:restaurant": "npm run dev --workspace=services/restaurant",
    "dev:rider":      "npm run dev --workspace=services/rider",
    "dev:utils":      "npm run dev --workspace=services/utils",
    "dev:admin":      "npm run dev --workspace=services/admin",
    "dev:realtime":   "npm run dev --workspace=services/realtime"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}