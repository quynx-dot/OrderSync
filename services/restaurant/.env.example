# services/restaurant/.env.example
MONGO_URI=
DB_NAME=OrderSync
JWT_SEC=
PORT=5001
UTILS_SERVICE=http://localhost:5002
REALTIME_SERVICE=http://localhost:5004
RIDER_SERVICE=http://localhost:5005
RABBITMQ_URL=amqp://localhost
PAYMENT_QUEUE=payment_queue
